; Exercises edge cases the example programs do not. Expected output:
;   -42 / 1 / -3 / -1 / 16 / 64 / 255 / 15 / 85 / 123456789 / 200 / 777

    ldi r0, -42
    sys 2
    call Nl

    ldi r1, -5
    cmpi r1, 3
    jl Less
    ldi r0, 0
    jmp PrintCmp
Less:
    ldi r0, 1
PrintCmp:
    sys 2
    call Nl

    ldi r1, -7
    ldi r2, 2
    mov r0, r1
    div r0, r2          ; -3
    sys 2
    call Nl
    mov r0, r1
    mod r0, r2          ; -1
    sys 2
    call Nl

    ldi r0, 1
    shli r0, 4          ; 16
    sys 2
    call Nl
    ldi r0, 256
    shri r0, 2          ; 64
    sys 2
    call Nl

    ldi r0, 0xF0
    ldi r1, 0x0F
    or r0, r1           ; 255
    sys 2
    call Nl
    ldi r0, 0xFF
    ldi r1, 0x0F
    and r0, r1          ; 15
    sys 2
    call Nl
    ldi r0, 0xAA
    ldi r1, 0xFF
    xor r0, r1          ; 85
    sys 2
    call Nl

    ldi r1, Buffer
    ldi r0, 123456789
    st r1, r0, 0
    ldi r0, 0
    ld r0, r1, 0        ; 123456789
    sys 2
    call Nl

    ldi r0, 200
    stb r1, r0, 8
    ldi r0, 0
    ldb r0, r1, 8       ; 200
    sys 2
    call Nl

    ldi r0, 777
    push r0
    ldi r0, 0
    pop r0              ; 777
    sys 2
    call Nl

    ldi r0, 0
    sys 0

Nl:
    push r0
    ldi r0, '\n'
    sys 1
    pop r0
    ret

Buffer:
    .space 16
